# Your AssemblyAI API key. Get one at https://www.assemblyai.com/app
# This key stays SERVER-SIDE only. The browser never sees it — the server uses it
# to mint short-lived temporary tokens for each WebSocket connection.
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Port the local demo server listens on (optional, defaults to 3000)
PORT=3000
